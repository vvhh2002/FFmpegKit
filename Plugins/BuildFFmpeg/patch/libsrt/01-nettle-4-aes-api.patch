+    switch (aes_key->key_len) {
+    case AES128_KEY_SIZE:
+        aes128_decrypt(&aes_key->ctx.aes128, len, out_txt, indata);
+        return 0;
+    case AES192_KEY_SIZE:
+        aes192_decrypt(&aes_key->ctx.aes192, len, out_txt, indata);
+        return 0;
+    case AES256_KEY_SIZE:
+        aes256_decrypt(&aes_key->ctx.aes256, len, out_txt, indata);
+        return 0;
+    default:
+        return -1;
+    }
+}
