+static int crysprGnuTLS_AES_Encrypt(
+    CRYSPR_AESCTX *aes_key,
+    size_t len,
+    unsigned char *out_txt,
+    const unsigned char *indata)
+{
+    switch (aes_key->key_len) {
+    case AES128_KEY_SIZE:
+        aes128_encrypt(&aes_key->ctx.aes128, len, out_txt, indata);
+        return 0;
+    case AES192_KEY_SIZE:
+        aes192_encrypt(&aes_key->ctx.aes192, len, out_txt, indata);
+        return 0;
+    case AES256_KEY_SIZE:
+        aes256_encrypt(&aes_key->ctx.aes256, len, out_txt, indata);
+        return 0;
+    default:
+        return -1;
+    }
+}
+
+static int crysprGnuTLS_AES_Decrypt(
+    CRYSPR_AESCTX *aes_key,
+    size_t len,
+    unsigned char *out_txt,
+    const unsigned char *indata)
